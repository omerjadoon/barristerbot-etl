# ─── Legal Dataset Files ───────────────────────────────────────────────────────
# Raw court judgment PDFs (large binary files, not for version control)
**/*.pdf

# Processed pipeline output caches (globally ignored)
**/*.jsonl

# ─── Data Warehouse Directories & Exclusions ───────────────────────────────────
# Ignore all files and folders in data_warehouse by default
data_warehouse/**/*

# Allow Git to traverse down to the specific directories we want to track
!data_warehouse/
!data_warehouse/bronze/
!data_warehouse/bronze/raw/
!data_warehouse/bronze/raw/phc/
!data_warehouse/bronze/archive/
!data_warehouse/bronze/archive/legal_codes/
!data_warehouse/silver/
!data_warehouse/gold/

# Un-ignore the specific files we want to keep in the repository
!data_warehouse/bronze/raw/phc/metadata.csv
!data_warehouse/bronze/archive/legal_codes/CPC.jsonl
!data_warehouse/bronze/archive/legal_codes/CrPC.jsonl
!data_warehouse/bronze/archive/legal_codes/Qanoon-e-Shahadat.jsonl
!data_warehouse/bronze/archive/legal_codes/PPC.jsonl
!data_warehouse/silver/example.jsonl
!data_warehouse/gold/example.jsonl

# Ignore generated outputs/caches outside the warehouse
processed/

# ─── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# ─── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover
coverage.xml

# ─── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfile ARE committed)

# ─── Airflow ───────────────────────────────────────────────────────────────────
logs/
airflow.db
airflow.cfg

# ─── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ─── IDEs & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
